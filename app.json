{
  "expo": {
    "name": "Dotivo",
    "slug": "dotivo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./.assets/images/dotivo-icon.png",
    "scheme": "dotivo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./.assets/images/dotivo-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.niraj11parihar.dotivo"
    },
    "web": {
      "output": "static",
      "favicon": "./.assets/images/dotivo-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./.assets/images/dotivo-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-sqlite",
      "./src/plugins/withWallpaper.js",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b9de090-4a2d-4bfa-acc1-f46128163dda"
      }
    }
  }
}
